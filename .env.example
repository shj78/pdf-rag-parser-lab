# Lab identity
LAB_NAME=pdf-rag-parser-lab
LAB_ENV=local

# Input and output locations
DATA_DIR=./data
OUTPUT_DIR=./artifacts
DEFAULT_EXPERIMENT_CONFIG=./config.example.yaml

# Parser defaults
DEFAULT_PARSER=pdfplumber
DEFAULT_CHUNKER=fixed_size
DEFAULT_PARSER_COMPARE_SET=pdfplumber,pymupdf,opendataloader

# Retrieval defaults
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_INDEX_BACKEND=placeholder
DEFAULT_TOP_K=10

# Existing reranker bridge
EXISTING_RERANKER_MODE=python_module
EXISTING_RERANKER_ENDPOINT=
EXISTING_RERANKER_ENTRYPOINT=
EXISTING_RERANKER_TIMEOUT_SECONDS=30

# Evaluation defaults
DEFAULT_EVAL_METRIC=ndcg
DEFAULT_EVAL_K=10
RELEVANCE_LABEL_SOURCE=manual

# Optional vendor credentials
OPENAI_API_KEY=

# UI
STREAMLIT_SERVER_PORT=8501
